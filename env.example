"""
Project Blackbird — Alpha 1
FastAPI application entrypoint
"""
import logging
from contextlib import asynccontextmanager

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from fastapi.staticfiles import StaticFiles
import os

from app.core.config import settings
from app.core.database import engine, Base
from app.routers import (
    missions, drones, images, detections, assets, reports, websocket
)
from app.routers.assets import assets_router, mission_images_router

logging.basicConfig(
    level=logging.DEBUG if settings.debug else logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
)
logger = logging.getLogger("blackbird")


@asynccontextmanager
async def lifespan(app: FastAPI):
    logger.info("🚁 Project Blackbird Alpha-1 starting up...")
    # Seed default assets and drones if DB is empty
    await _seed_defaults()
    yield
    logger.info("Blackbird shutting down.")


async def _seed_defaults():
    """Seed demo drones and solar farm assets on first run."""
    from sqlalchemy import text, select
    from app.core.database import AsyncSessionLocal
    from app.models.models import Drone, Asset, AssetType, DroneStatus
    import uuid

    async with AsyncSessionLocal() as db:
        # Check if already seeded
        result = await db.execute(select(Drone).limit(1))
        if result.scalar_one_or_none():
            return

        logger.info("Seeding default drones and assets...")

        # Create 3 drones
        drones_data = [
            {"name": "Blackbird-01", "model": "BB-X1 Pro"},
            {"name": "Blackbird-02", "model": "BB-X1 Pro"},
            {"name": "Blackbird-03", "model": "BB-X1 Lite"},
        ]
        for d in drones_data:
            drone = Drone(
                id=str(uuid.uuid4()),
                name=d["name"],
                model=d["model"],
                status=DroneStatus.IDLE,
                battery_pct=100.0,
                lat=51.5074,
                lon=-0.1278,
            )
            db.add(drone)

        # Create solar farm assets (5x5 grid as demo)
        base_lat, base_lon = 51.5074, -0.1278
        spacing = 0.0002  # ~22m
        idx = 0
        for row in range(5):
            for col in range(5):
                asset = Asset(
                    id=str(uuid.uuid4()),
                    name=f"Panel-{idx:03d}",
                    asset_type=AssetType.SOLAR_PANEL,
                    lat=base_lat + row * spacing,
                    lon=base_lon + col * spacing,
                    elevation=0.0,
                    condition_score=100.0 - (idx % 5) * 5,
                )
                db.add(asset)
                idx += 1

        # A few wind turbines
        for i in range(3):
            asset = Asset(
                id=str(uuid.uuid4()),
                name=f"Turbine-{i+1:02d}",
                asset_type=AssetType.WIND_TURBINE,
                lat=base_lat + 0.01 + i * 0.003,
                lon=base_lon + 0.005,
                elevation=5.0,
                condition_score=95.0 - i * 10,
            )
            db.add(asset)

        await db.commit()
        logger.info("Default seed complete.")


app = FastAPI(
    title="Project Blackbird",
    description="Autonomous Drone Inspection Platform — Alpha 1",
    version="1.0.0-alpha",
    lifespan=lifespan,
)

# CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # Tighten in production
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Mount uploads as static
os.makedirs(settings.upload_dir, exist_ok=True)
app.mount("/uploads", StaticFiles(directory=settings.upload_dir), name="uploads")

# Routers
app.include_router(missions.router)
app.include_router(drones.router)
app.include_router(images.router)
app.include_router(detections.router)
app.include_router(assets_router)
app.include_router(mission_images_router)
app.include_router(reports.router)
app.include_router(websocket.router)


@app.get("/health")
async def health():
    return {
        "status": "ok",
        "service": "blackbird-backend",
        "version": "1.0.0-alpha",
    }


@app.get("/")
async def root():
    return {
        "name": "Project Blackbird Alpha-1",
        "docs": "/docs",
        "health": "/health",
    }
